{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": {
      "*": "allow",
    },
  },
  "agent": {
    "ralph": {
      "description": "Solves one issue",
      "temperature": 0.25,
      "variant": "max",
      "prompt": "{file:./PROMPT.xml}",
      "mode": "primary",
    },
  },
}
